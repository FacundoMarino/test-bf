# URL base del auth-service (Nest en Serxus)
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:3001

# Nombre de la cookie donde Next guarda el access token (HttpOnly).
# Debe ser un valor acordado en tu despliegue; el token lo devuelve POST /auth/sign-in.
SESSION_COOKIE_NAME=auth_session

NODE_ENV=development
